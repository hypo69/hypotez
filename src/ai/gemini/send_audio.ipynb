        "import os\n",
        "from google import genai\n",
        "from google.ai import generativelanguage as glm\n",
        "\n",
        "\n",
        "def generate_from_gcs(gcs_uri):\n",
        "    \"\"\"\n",
        "    袚械薪械褉懈褉褍械褌 褌械泻褋褌 薪邪 芯褋薪芯胁械 邪褍写懈芯褎邪泄谢邪, 褏褉邪薪褟褖械谐芯褋褟 胁 Google Cloud Storage.\n",
        "\n",
        "    Args:\n",
        "        gcs_uri: URI 邪褍写懈芯褎邪泄谢邪 胁 GCS (薪邪锌褉懈屑械褉, \"gs://your-bucket/audio.mp3\").\n",
        "    \"\"\"\n",
        "\n",
        "    client = genai.Client(\n",
        "        api_key=\"啸啸啸啸啸啸啸啸啸啸啸啸啸啸啸啸啸啸啸啸啸啸啸啸啸啸啸啸\",  # 袟袗袦袝袧袠孝袝 袧袗 小袙袨袡 API KEY\n",
        "    )\n",
        "\n",
        "    model = \"gemini-2.0-flash\"  # 袠谢懈 写褉褍谐邪褟 锌芯写褏芯写褟褖邪褟 屑芯写械谢褜\n",
        "\n",
        "    prompt = f\"\"\"袩褉械芯斜褉邪蟹褍泄 邪褍写懈芯褎邪泄谢, 褉邪褋锌芯谢芯卸械薪薪褘泄 锌芯 邪写褉械褋褍 {gcs_uri}, 胁 褌械泻褋褌 懈 薪邪锌懈褕懈 泻褉邪褌泻芯械 褋芯写械褉卸邪薪懈械.\"\"\"\n",
        "\n",
        "    contents = [\n",
        "        glm.Content(\n",
        "            role=\"user\",\n",
        "            parts=[glm.Part(text=prompt)],\n",
        "        ),\n",
        "    ]\n",
        "\n",
        "    generate_content_config = glm.GenerateContentConfig(\n",
        "        temperature=0.7,\n",
        "        top_p=0.95,\n",
        "        top_k=40,\n",
        "        max_output_tokens=1024,\n",
        "    )\n",
        "\n",
        "    try:\n",
        "        response = client.models.generate_content(\n",
        "            model=model,\n",
        "            contents=contents,\n",
        "            config=generate_content_config,\n",
        "        )\n",
        "\n",
        "        if response.prompt_feedback and response.prompt_feedback.block_reason:\n",
        "            print(f\"袨褌胁械褌 蟹邪斜谢芯泻懈褉芯胁邪薪: {response.prompt_feedback.block_reason}\")\n",
        "        else:\n",
        "            print(response.text)\n",
        "    except Exception as e:\n",
        "        print(f\"袩褉芯懈蟹芯褕谢邪 芯褕懈斜泻邪 锌褉懈 胁褘蟹芯胁械 API: {e}\")\n",
        "\n",
        "\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    gcs_file = \"gs://your-bucket/audio.mp3\" # 袟袗袦袝袧袠孝袝 袧袗 URI 袙袗楔袝袚袨 肖袗袡袥袗 袙 GCS\n",
        "    generate_from_gcs(gcs_file)"
      ]
